<?xml version="1.0"?>
<DTS:Executable xmlns:DTS="www.microsoft.com/SqlServer/Dts"
  DTS:refId="Package"
  DTS:DTSID="{E5F6A7B8-C9D0-8E9F-2A3B-4C5D6E7F8A9B}"
  DTS:ExecutableType="Microsoft.Package"
  DTS:ObjectName="Extract_Inventory"
  DTS:PackageType="5">
  <DTS:Property DTS:Name="Description">Extracts inventory levels from Oracle inventory management system to staging</DTS:Property>
  <DTS:ConnectionManagers>
    <DTS:ConnectionManager DTS:refId="Package.ConnectionManagers[Oracle_Inventory]" DTS:CreationName="ADO.NET:ORACLE" DTS:ObjectName="Oracle_Inventory">
      <DTS:ObjectData>
        <DTS:ConnectionManager DTS:ConnectionString="Data Source=INVDB;User ID=etl_reader;Password=***;" />
      </DTS:ObjectData>
    </DTS:ConnectionManager>
    <DTS:ConnectionManager DTS:refId="Package.ConnectionManagers[Staging_Target]" DTS:CreationName="OLEDB" DTS:ObjectName="Staging_Target">
      <DTS:ObjectData>
        <DTS:ConnectionManager DTS:ConnectionString="Data Source=DW-SQL-SERVER;Initial Catalog=BrightfieldDW;Provider=SQLNCLI11.1;Integrated Security=SSPI;" />
      </DTS:ObjectData>
    </DTS:ConnectionManager>
  </DTS:ConnectionManagers>
  <DTS:Executables>
    <DTS:Executable DTS:refId="Package\Extract Inventory Levels" DTS:ExecutableType="Microsoft.Pipeline">
      <DTS:ObjectData>
        <pipeline>
          <components>
            <component name="Oracle Inventory Source" componentClassID="Microsoft.ADONETSource">
              <properties>
                <property name="SqlCommand">
                  SELECT STORE_ID, PRODUCT_ID, QUANTITY_ON_HAND, QUANTITY_ON_ORDER, 
                         LAST_RESTOCK_DATE, REORDER_POINT, SNAPSHOT_DATE
                  FROM INVENTORY.STOCK_LEVELS
                  WHERE SNAPSHOT_DATE = TRUNC(SYSDATE)
                </property>
              </properties>
              <outputs>
                <output name="ADO NET Source Output" />
              </outputs>
            </component>
            
            <component name="Data Conversion" componentClassID="Microsoft.DataConvert">
              <properties>
                <property name="Description">Convert Oracle NUMBER to SQL Server INT/DECIMAL</property>
              </properties>
              <inputs>
                <input refId="Oracle Inventory Source.Output" />
              </inputs>
              <outputs>
                <output name="Data Conversion Output" />
              </outputs>
            </component>
            
            <component name="Staging Destination" componentClassID="Microsoft.OLEDBDestination">
              <properties>
                <property name="TableName">staging.InventoryLevels</property>
                <property name="FastLoadOptions">TABLOCK</property>
              </properties>
              <inputs>
                <input refId="Data Conversion.Output" />
              </inputs>
            </component>
          </components>
        </pipeline>
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
</DTS:Executable>
