            </Code>
          </ScriptProject>
        </ScriptTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
    
    <DTS:Executable DTS:refId="Package\Validate JSON Data" DTS:ExecutableType="Microsoft.ExecuteSQLTask">
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="Staging_Target"
          SQLTask:SqlStatementSource="EXEC staging.ValidateEcommerceOrders" />
      </DTS:ObjectData>
