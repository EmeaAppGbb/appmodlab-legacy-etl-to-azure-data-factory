{
    "name": "trigger_tumbling_window_incremental",
    "type": "Microsoft.DataFactory/factories/triggers",
    "properties": {
        "description": "Tumbling window trigger for incremental data loads. Processes data in non-overlapping 24-hour windows with built-in retry and dependency tracking. Ensures no data gaps by guaranteeing each window is processed exactly once, even after failures.",
        "runtimeState": "Stopped",
        "type": "TumblingWindowTrigger",
        "typeProperties": {
            "frequency": "Hour",
            "interval": 24,
            "startTime": "2026-04-17T02:00:00Z",
            "delay": "00:00:00",
            "maxConcurrency": 1,
            "retryPolicy": {
                "count": 3,
                "intervalInSeconds": 600
            }
        },
        "pipeline": {
            "pipelineReference": {
                "referenceName": "pipeline_master_orchestrator",
                "type": "PipelineReference"
            },
            "parameters": {
                "ExecutionDate": "@trigger().outputs.windowStartTime"
            }
        },
        "annotations": [
            "tumbling-window",
            "incremental",
            "production"
        ]
    }
}
