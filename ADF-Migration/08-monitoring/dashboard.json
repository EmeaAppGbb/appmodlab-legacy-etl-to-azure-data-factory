{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "dashboardName": {
      "type": "string",
      "defaultValue": "ADF-ETL-Monitoring",
      "metadata": { "description": "Name of the Azure Portal dashboard." }
    },
    "dataFactoryResourceId": {
      "type": "string",
      "metadata": { "description": "Resource ID of the Azure Data Factory." }
    },
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "metadata": { "description": "Resource ID of the Log Analytics workspace." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Portal/dashboards",
      "apiVersion": "2020-09-01-preview",
      "name": "[parameters('dashboardName')]",
      "location": "[parameters('location')]",
      "tags": {
        "hidden-title": "ADF ETL Migration – Monitoring Dashboard"
      },
      "properties": {
        "lenses": [
          {
            "order": 0,
            "parts": [
              {
                "position": { "x": 0, "y": 0, "rowSpan": 4, "colSpan": 6 },
                "metadata": {
                  "type": "Extension/HubsExtension/PartType/MonitorChartPart",
                  "inputs": [
                    {
                      "name": "options",
                      "value": {
                        "chart": {
                          "title": "Pipeline Run Status (Last 24 h)",
                          "metrics": [
                            {
                              "resourceMetadata": { "id": "[parameters('dataFactoryResourceId')]" },
                              "name": "PipelineSucceededRuns",
                              "aggregationType": 1,
                              "namespace": "Microsoft.DataFactory/factories",
                              "metricVisualization": { "displayName": "Succeeded", "color": "#00AA00" }
                            },
                            {
                              "resourceMetadata": { "id": "[parameters('dataFactoryResourceId')]" },
                              "name": "PipelineFailedRuns",
                              "aggregationType": 1,
                              "namespace": "Microsoft.DataFactory/factories",
                              "metricVisualization": { "displayName": "Failed", "color": "#FF0000" }
                            },
                            {
                              "resourceMetadata": { "id": "[parameters('dataFactoryResourceId')]" },
                              "name": "PipelineCancelledRuns",
                              "aggregationType": 1,
                              "namespace": "Microsoft.DataFactory/factories",
                              "metricVisualization": { "displayName": "Cancelled", "color": "#FFA500" }
                            }
                          ],
                          "timespan": { "relative": { "duration": 86400000 } },
                          "visualization": { "chartType": 2 }
                        }
                      }
                    }
                  ]
                }
              },
              {
                "position": { "x": 6, "y": 0, "rowSpan": 4, "colSpan": 6 },
                "metadata": {
                  "type": "Extension/HubsExtension/PartType/MonitorChartPart",
                  "inputs": [
                    {
                      "name": "options",
                      "value": {
                        "chart": {
                          "title": "Activity Run Status (Last 24 h)",
                          "metrics": [
                            {
                              "resourceMetadata": { "id": "[parameters('dataFactoryResourceId')]" },
                              "name": "ActivitySucceededRuns",
                              "aggregationType": 1,
                              "namespace": "Microsoft.DataFactory/factories",
                              "metricVisualization": { "displayName": "Succeeded", "color": "#00AA00" }
                            },
                            {
                              "resourceMetadata": { "id": "[parameters('dataFactoryResourceId')]" },
                              "name": "ActivityFailedRuns",
                              "aggregationType": 1,
                              "namespace": "Microsoft.DataFactory/factories",
                              "metricVisualization": { "displayName": "Failed", "color": "#FF0000" }
                            }
                          ],
                          "timespan": { "relative": { "duration": 86400000 } },
                          "visualization": { "chartType": 2 }
                        }
                      }
                    }
                  ]
                }
              },
              {
                "position": { "x": 0, "y": 4, "rowSpan": 4, "colSpan": 6 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "inputs": [
                    {
                      "name": "resourceId",
                      "value": "[parameters('logAnalyticsWorkspaceId')]"
                    },
                    {
                      "name": "query",
                      "value": "ADFActivityRun\n| where Status == 'Succeeded' and ActivityType == 'Copy'\n| extend DurationSec = datetime_diff('second', End, Start)\n| summarize AvgDuration = avg(DurationSec), P95Duration = percentile(DurationSec, 95) by ActivityName, bin(TimeGenerated, 1h)\n| order by TimeGenerated desc\n| take 50"
                    },
                    {
                      "name": "title",
                      "value": "Activity Durations – Avg & P95 (Copy Activities)"
                    }
                  ]
                }
              },
              {
                "position": { "x": 6, "y": 4, "rowSpan": 4, "colSpan": 6 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "inputs": [
                    {
                      "name": "resourceId",
                      "value": "[parameters('logAnalyticsWorkspaceId')]"
                    },
                    {
                      "name": "query",
                      "value": "ADFPipelineRun\n| where Status == 'Failed'\n| summarize FailureCount = count() by PipelineName, bin(TimeGenerated, 1h)\n| order by TimeGenerated desc\n| take 50"
                    },
                    {
                      "name": "title",
                      "value": "Pipeline Error Rate (Hourly)"
                    }
                  ]
                }
              },
              {
                "position": { "x": 0, "y": 8, "rowSpan": 4, "colSpan": 6 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "inputs": [
                    {
                      "name": "resourceId",
                      "value": "[parameters('logAnalyticsWorkspaceId')]"
                    },
                    {
                      "name": "query",
                      "value": "ADFActivityRun\n| where ActivityType == 'Copy' and Status == 'Succeeded'\n| extend RowsRead = toint(parse_json(Output).rowsRead)\n| extend RowsCopied = toint(parse_json(Output).rowsCopied)\n| extend DataRead = tolong(parse_json(Output).dataRead)\n| summarize TotalRowsRead = sum(RowsRead), TotalRowsCopied = sum(RowsCopied), TotalDataMB = round(sum(DataRead) / 1048576.0, 2) by PipelineName, bin(TimeGenerated, 1h)\n| order by TimeGenerated desc\n| take 50"
                    },
                    {
                      "name": "title",
                      "value": "Row Counts & Data Volume (Copy Activities)"
                    }
                  ]
                }
              },
              {
                "position": { "x": 6, "y": 8, "rowSpan": 4, "colSpan": 6 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "inputs": [
                    {
                      "name": "resourceId",
                      "value": "[parameters('logAnalyticsWorkspaceId')]"
                    },
                    {
                      "name": "query",
                      "value": "ADFPipelineRun\n| where Status == 'InProgress'\n| extend DurationMin = datetime_diff('minute', now(), Start)\n| project PipelineName, RunId, Start, DurationMin\n| order by DurationMin desc\n| take 20"
                    },
                    {
                      "name": "title",
                      "value": "Currently Running Pipelines"
                    }
                  ]
                }
              },
              {
                "position": { "x": 0, "y": 12, "rowSpan": 4, "colSpan": 12 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "inputs": [
                    {
                      "name": "resourceId",
                      "value": "[parameters('logAnalyticsWorkspaceId')]"
                    },
                    {
                      "name": "query",
                      "value": "ADFPipelineRun\n| summarize Succeeded = countif(Status == 'Succeeded'), Failed = countif(Status == 'Failed'), Cancelled = countif(Status == 'Cancelled') by bin(TimeGenerated, 1d)\n| extend SuccessRate = round(todouble(Succeeded) / todouble(Succeeded + Failed + Cancelled) * 100, 2)\n| order by TimeGenerated desc\n| take 30"
                    },
                    {
                      "name": "title",
                      "value": "Daily Pipeline Success Rate (Last 30 Days)"
                    }
                  ]
                }
              }
            ]
          }
        ],
        "metadata": {
          "model": {
            "timeRange": {
              "type": "MsPortalFx.Composition.Configuration.ValueTypes.TimeRange",
              "value": { "relative": { "duration": 24, "timeUnit": 1 } }
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "dashboardResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Portal/dashboards', parameters('dashboardName'))]"
    }
  }
}
